
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check relies solely on the Firebase custom claim `admin: true`.
    // Set this server-side via Firebase Admin SDK or Cloud Functions.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
          && (request.resource.contentType.matches('image/.*'));
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage();
    }

    match /products/{userId}/{productId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage();
    }

    match /deliveries/{deliveryId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidImage();
    }
  }
}
