
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // By default, allow files to be read by anyone, but not written.
    // This allows product images, etc., to be publicly visible.
    allow read: if true;
    allow write: if false;

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to validate image properties.
    function isAllowedImage(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024
          && (
            request.resource.contentType.matches('image/jpeg') ||
            request.resource.contentType.matches('image/png') ||
            request.resource.contentType.matches('image/webp')
          );
    }

    // Users can only write to their own profile folder.
    // e.g., /users/{userId}/profile.jpg
    match /users/{userId}/{fileName} {
      allow write: if isSignedIn() 
                  && request.auth.uid == userId 
                  && isAllowedImage(5);
    }

    // Product images can only be written by the product's seller.
    // Note: This rule requires the Firestore product document to exist before the image is uploaded.
    // e.g., /products/{productId}/image1.jpg
    match /products/{productId}/{fileName} {
      allow write: if isSignedIn()
                  && get(/databases/$(database)/documents/products/$(productId)).data.sellerId == request.auth.uid
                  && isAllowedImage(10);
    }

    // Delivery proofs can only be written by the assigned courier.
    // e.g., /deliveries/{deliveryId}/proof.jpg
    match /deliveries/{deliveryId}/{fileName} {
      allow write: if isSignedIn()
                  && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.courierId == request.auth.uid
                  && isAllowedImage(10);
    }
  }
}
