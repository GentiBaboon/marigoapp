
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the Marigo Luxe marketplace.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "role": {
          "type": "string",
          "enum": [
            "buyer",
            "seller",
            "courier",
            "admin"
          ],
          "default": "buyer",
          "description": "The user's primary role in the platform."
        },
        "profileImage": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture stored in Storage."
        },
        "bio": {
          "type": "string",
          "description": "A short biography of the user."
        },
        "language": {
          "type": "string",
          "enum": [
            "sq",
            "en",
            "it"
          ],
          "default": "en",
          "description": "The user's preferred language."
        },
        "currency": {
          "type": "string",
          "enum": [
            "EUR",
            "ALL",
            "USD"
          ],
          "default": "EUR",
          "description": "The user's preferred currency for display."
        },
        "stripeCustomerId": {
          "type": "string",
          "description": "The user's Stripe Customer ID for buying."
        },
        "stripeAccountId": {
          "type": "string",
          "description": "The user's Stripe Connected Account ID for selling."
        },
        "rating": {
          "type": "number",
          "default": 0,
          "description": "The average rating score of the user."
        },
        "reviewCount": {
          "type": "number",
          "default": 0,
          "description": "Total number of reviews received."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of user creation."
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last login."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "banned"
          ],
          "default": "active",
          "description": "The user's account status."
        }
      },
      "required": [
        "email",
        "createdAt",
        "role"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a luxury product listed on the marketplace.",
      "properties": {
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "brandId": { "type": "string" },
        "condition": { "type": "string" },
        "listingType": { "type": "string", "enum": ["fixed_price", "auction"] },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "currency": { "type": "string", "default": "EUR" },
        "size": { "type": "string" },
        "color": { "type": "string" },
        "material": { "type": "string" },
        "gender": { "type": "string", "enum": ["women", "men", "children", "unisex"] },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "thumbnailUrl": { "type": "string", "format": "uri" },
              "position": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["draft", "pending_review", "active", "sold", "removed", "expired"] },
        "views": { "type": "number", "default": 0 },
        "wishlistCount": { "type": "number", "default": 0 },
        "isFeatured": { "type": "boolean", "default": false },
        "isAuthenticated": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "price", "status", "createdAt", "images"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "parentId": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "Attribute": {
      "title": "Metadata Attribute",
      "type": "object",
      "description": "Used for Conditions, Materials, Colors, Patterns.",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "hex": { "type": "string", "description": "Optional hex for colors" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com",
      "apple.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Product listings."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories."
    },
    "/brands/{brandId}": {
      "schema": { "$ref": "#/entities/Brand" },
      "description": "Designer brands."
    },
    "/conditions/{id}": { "schema": { "$ref": "#/entities/Attribute" }, "description": "Product conditions." },
    "/materials/{id}": { "schema": { "$ref": "#/entities/Attribute" }, "description": "Product materials." },
    "/colors/{id}": { "schema": { "$ref": "#/entities/Attribute" }, "description": "Product colors." },
    "/patterns/{id}": { "schema": { "$ref": "#/entities/Attribute" }, "description": "Product patterns." },
    "/settings/global": { "description": "Global marketplace settings." }
  }
}
