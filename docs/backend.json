{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the MarigoApp marketplace.",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
            "type": "string",
            "format": "uri",
            "description": "URL of the user's profile picture."
        },
        "macroCategoryPreference": {
          "type": "string",
          "enum": [
            "womenswear",
            "menswear"
          ],
          "description": "The user's preferred shopping category."
        },
        "hasAcceptedChatRules": {
          "type": "boolean",
          "description": "Whether the user has accepted the chat rules."
        },
        "isSeller": {
          "type": "boolean",
          "description": "Whether the user is a seller."
        },
        "isCourier": {
          "type": "boolean",
          "description": "Whether the user has applied to be a courier."
        },
        "courierStatus": {
          "type": "string",
          "enum": ["pending_approval", "approved", "rejected"],
          "description": "The status of the user's courier application."
        },
        "stripeAccountId": {
          "type": "string",
          "description": "The user's Stripe Connected Account ID."
        },
        "stripeOnboardingComplete": {
            "type": "boolean",
            "description": "Whether the user has completed Stripe onboarding."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of user creation."
        },
        "status": {
          "type": "string",
          "enum": ["active", "banned"],
          "default": "active",
          "description": "The user's account status."
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Address": {
      "title": "Address",
      "type": "object",
      "description": "Represents a user's address.",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postal": { "type": "string" },
        "country": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["fullName", "address", "city", "postal", "country"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "type": "object",
      "description": "Represents a user's payment method.",
      "properties": {
        "type": { "type": "string" },
        "stripePaymentMethodId": { "type": "string" },
        "last4": { "type": "string" },
        "brand": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["stripePaymentMethodId", "last4", "brand"]
    },
    "WishlistItem": {
        "title": "WishlistItem",
        "type": "object",
        "description": "Represents a product in a user's wishlist.",
        "properties": {
            "addedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["addedAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a product category.",
      "properties": {
        "name": { "type": "object", "properties": { "sq": { "type": "string" }, "en": { "type": "string" }, "it": { "type": "string" } } },
        "slug": { "type": "string" },
        "parentId": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "position": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "slug", "isActive"]
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "description": "Represents a product brand.",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "verified": { "type": "boolean" },
        "productCount": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed on the marketplace.",
      "properties": {
        "sellerId": { "type": "string", "description": "Reference to the user who is selling the item." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "status": { "type": "string", "enum": ["active", "sold", "reserved", "pending_review"] },
        "listingCreated": { "type": "string", "format": "date-time" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "Keywords for search." },
        "brand": { "type": "string" },
        "size": { "type": "string" },
        "condition": { "type": "string" },
        "material": { "type": "string" },
        "color": { "type": "string" },
        "pattern": { "type": "string" },
        "vintage": { "type": "boolean" }
      },
      "required": ["sellerId", "title", "price", "category", "images", "status", "listingCreated"]
    },
    "Offer": {
      "title": "Offer",
      "type": "object",
      "description": "Represents an offer made on a product.",
      "properties": {
        "productId": { "type": "string", "$ref": "#/entities/Product" },
        "buyerId": { "type": "string", "$ref": "#/entities/User" },
        "sellerId": { "type": "string", "$ref": "#/entities/User" },
        "originalListingPrice": { "type": "number" },
        "offerAmount": { "type": "number" },
        "offerType": { "type": "string", "enum": ["preset_1", "preset_2", "preset_3", "custom"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "countered"] },
        "counterOfferAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "amount": { "type": "number" },
              "byUser": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            },
            "required": ["action", "amount", "byUser", "timestamp"]
          }
        }
      },
      "required": ["productId", "buyerId", "sellerId", "offerAmount", "status", "createdAt"]
    },
    "Bid": {
      "title": "Bid",
      "type": "object",
      "description": "Represents a bid on an auction product.",
      "properties": {
        "bidderId": { "type": "string" },
        "amount": { "type": "number" },
        "isAutoBid": { "type": "boolean" },
        "maxAutoBidAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bidderId", "amount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents an order.",
      "properties": {
        "orderNumber": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerIds": { "type": "array", "items": { "type": "string" } },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "sellerId": { "type": "string" },
              "title": { "type": "string" },
              "brand": { "type": "string" },
              "image": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "size": { "type": "string" }
            },
            "required": ["productId", "sellerId", "title", "price", "quantity"]
          }
        },
        "shippingPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentIntentId": { "type": "string" },
        "status": { "type": "string" },
        "shippingAddress": { "$ref": "#/entities/Address" },
        "trackingNumber": { "type": "string" },
        "courierCompany": { "type": "string" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "buyerId", "sellerIds", "items", "totalAmount", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "description": "Represents a conversation between users.",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "productId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Represents a message in a conversation.",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "createdAt"]
    },
    "Review": {
        "title": "Review",
        "type": "object",
        "description": "Represents a review for an order.",
        "properties": {
            "orderId": { "type": "string" },
            "reviewerId": { "type": "string" },
            "revieweeId": { "type": "string" },
            "productId": { "type": "string" },
            "rating": { "type": "number" },
            "title": { "type": "string" },
            "content": { "type": "string" }
        },
        "required": ["orderId", "reviewerId", "revieweeId", "rating"]
    },
    "Notification": {
        "title": "Notification",
        "type": "object",
        "description": "Represents a user notification.",
        "properties": {
            "userId": { "type": "string" },
            "type": { "type": "string" },
            "title": { "type": "string" },
            "message": { "type": "string" },
            "data": { "type": "object" },
            "read": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "type", "message", "createdAt"]
    },
    "Delivery": {
      "title": "Delivery",
      "type": "object",
      "description": "Represents a delivery assignment.",
      "properties": {
        "orderId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerIds": { "type": "array", "items": { "type": "string" } },
        "courierId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "pending_assignment",
            "assigned",
            "arrived_for_pickup",
            "picked_up",
            "in_transit",
            "arrived_for_delivery",
            "delivered",
            "cancelled"
          ]
        },
        "addresses": {
          "type": "object",
          "properties": {
            "pickup": { "$ref": "#/entities/Address" },
            "delivery": { "$ref": "#/entities/Address" }
          }
        },
        "pickupNotes": { "type": "string" },
        "pickupSignature": { "type": "string", "format": "uri" },
        "proofOfPickup": { "type": "string", "format": "uri" },
        "proofOfDelivery": { "type": "string", "format": "uri" },
        "deliveryFee": { "type": "number" },
        "packageSize": { "type": "string", "enum": ["small", "medium", "large"] },
        "timeEstimate": {
          "type": "number",
          "description": "Estimated delivery time in minutes"
        },
        "specialInstructions": { "type": "string" },
        "distance": { "type": "number", "description": "Distance in kilometers" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          },
          "description": "The courier's current GPS location."
        },
        "history": {
          "type": "array",
          "description": "A log of status changes and events for the delivery.",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "notes": { "type": "string" }
            }
          }
        }
      },
      "required": ["orderId", "status"]
    },
    "CourierProfile": {
      "title": "CourierProfile",
      "type": "object",
      "description": "Represents a courier's detailed profile.",
      "properties": {
        "userId": { "type": "string" },
        "legalName": { "type": "string" },
        "phone": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "vehicleType": { "type": "string", "enum": ["bicycle", "scooter", "car", "van"] },
        "licensePlate": { "type": "string" },
        "serviceAreas": { "type": "string" },
        "availability": { "type": "array", "items": { "type": "string" } },
        "isAvailable": { "type": "boolean", "default": true }
      },
      "required": ["userId", "legalName", "phone", "dob", "vehicleType", "serviceAreas"]
    },
    "Report": {
        "title": "Report",
        "type": "object",
        "description": "Represents a user-submitted report for content moderation.",
        "properties": {
          "reporterId": { "type": "string" },
          "type": { "type": "string", "enum": ["product", "user", "message", "review"] },
          "itemId": { "type": "string" },
          "reason": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "resolved"], "default": "pending" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["reporterId", "type", "itemId", "reason", "status", "createdAt"]
    },
    "AdminLog": {
        "title": "AdminLog",
        "type": "object",
        "description": "Represents an action taken by an administrator.",
        "properties": {
            "adminId": { "type": "string" },
            "adminName": { "type": "string" },
            "actionType": { "type": "string", "enum": ["product_approved", "product_rejected", "user_banned", "user_unbanned", "user_role_changed", "order_status_updated", "setting_changed"] },
            "details": { "type": "string" },
            "targetId": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["adminId", "actionType", "details", "targetId", "timestamp"]
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "description": "Global settings for the marketplace.",
      "properties": {
        "commissionRate": {
          "type": "number",
          "description": "The platform's commission rate as a decimal (e.g., 0.15 for 15%)."
        },
        "maintenanceMode": {
          "type": "boolean",
          "description": "Whether the site is in maintenance mode."
        }
      },
      "required": ["commissionRate", "maintenanceMode"]
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "description": "Represents a discount coupon.",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "expired", "disabled"] }
      },
      "required": ["code", "discountType", "discountValue", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "apple.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and core information."
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "Subcollection for a user's shipping addresses."
    },
    "/users/{userId}/paymentMethods/{methodId}": {
      "schema": { "$ref": "#/entities/PaymentMethod" },
      "description": "Subcollection for a user's payment methods."
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": { "$ref": "#/entities/WishlistItem" },
      "description": "Subcollection for a user's wishlist/favorites."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Top-level collection for product categories."
    },
    "/brands/{brandId}": {
      "schema": { "$ref": "#/entities/Brand" },
      "description": "Top-level collection for product brands."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Top-level collection for all product listings."
    },
    "/products/{productId}/offers/{offerId}": {
      "schema": { "$ref": "#/entities/Offer" },
      "description": "Subcollection for offers made on a specific product."
    },
    "/products/{productId}/bids/{bidId}": {
      "schema": { "$ref": "#/entities/Bid" },
      "description": "Subcollection for bids on an auction product."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Top-level collection for all completed orders."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Top-level collection for conversations between users."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Subcollection for messages within a conversation."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Top-level collection for all reviews."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Top-level collection for user notifications."
    },
    "/deliveries/{deliveryId}": {
      "schema": { "$ref": "#/entities/Delivery" },
      "description": "Top-level collection for delivery assignments."
    },
    "/courier_profiles/{userId}": {
      "schema": { "$ref": "#/entities/CourierProfile" },
      "description": "Stores detailed profiles for delivery couriers."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Top-level collection for user-submitted content reports."
    },
    "/roles_admin/{userId}": {
      "schema": { "type": "object", "properties": {} },
      "description": "Stores admin user roles for access control."
    },
    "/admin_logs/{logId}": {
      "schema": { "$ref": "#/entities/AdminLog" },
      "description": "Stores a non-deletable audit trail of all administrator actions."
    },
    "/settings/global": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global application settings in a single document."
    },
    "/coupons/{couponId}": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Collection of all discount coupons."
    }
  }
}
