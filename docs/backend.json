{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the MarigoApp marketplace.",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "macroCategoryPreference": {
          "type": "string",
          "enum": [
            "womenswear",
            "menswear"
          ],
          "description": "The user's preferred shopping category."
        },
        "hasAcceptedChatRules": {
          "type": "boolean",
          "description": "Whether the user has accepted the chat rules."
        },
        "isSeller": {
          "type": "boolean",
          "description": "Whether the user is a seller."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of user creation."
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Address": {
      "title": "Address",
      "type": "object",
      "description": "Represents a user's address.",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postal": { "type": "string" },
        "country": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["fullName", "address", "city", "postal", "country"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "type": "object",
      "description": "Represents a user's payment method.",
      "properties": {
        "type": { "type": "string" },
        "stripePaymentMethodId": { "type": "string" },
        "last4": { "type": "string" },
        "brand": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["stripePaymentMethodId", "last4", "brand"]
    },
    "WishlistItem": {
        "title": "WishlistItem",
        "type": "object",
        "description": "Represents a product in a user's wishlist.",
        "properties": {
            "addedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["addedAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a product category.",
      "properties": {
        "name": { "type": "object", "properties": { "sq": { "type": "string" }, "en": { "type": "string" }, "it": { "type": "string" } } },
        "slug": { "type": "string" },
        "parentId": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "position": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "slug", "isActive"]
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "description": "Represents a product brand.",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "verified": { "type": "boolean" },
        "productCount": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed on the marketplace.",
      "properties": {
        "sellerId": { "type": "string", "description": "Reference to the user who is selling the item." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "status": { "type": "string", "enum": ["active", "sold", "reserved", "pending_review", "removed", "expired", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "brand": { "type": "string" },
        "size": { "type": "string" },
        "condition": { "type": "string" },
        "material": { "type": "string" },
        "color": { "type": "string" },
        "pattern": { "type": "string" },
        "vintage": { "type": "boolean" }
      },
      "required": ["sellerId", "title", "price", "category", "images", "status", "createdAt", "brand", "condition", "material", "color"]
    },
    "Offer": {
      "title": "Offer",
      "type": "object",
      "description": "Represents an offer made on a product.",
      "properties": {
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "countered"] },
        "counterAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "amount": { "type": "number" },
              "by_user": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            },
            "required": ["action", "amount", "by_user", "timestamp"]
          }
        }
      },
      "required": ["buyerId", "sellerId", "amount", "status", "createdAt"]
    },
    "Bid": {
      "title": "Bid",
      "type": "object",
      "description": "Represents a bid on an auction product.",
      "properties": {
        "bidderId": { "type": "string" },
        "amount": { "type": "number" },
        "isAutoBid": { "type": "boolean" },
        "maxAutoBidAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bidderId", "amount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents an order.",
      "properties": {
        "orderNumber": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerIds": { "type": "array", "items": { "type": "string" } },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "sellerId": { "type": "string" },
              "title": { "type": "string" },
              "brand": { "type": "string" },
              "image": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "size": { "type": "string" }
            },
            "required": ["productId", "sellerId", "title", "price", "quantity"]
          }
        },
        "shippingPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentIntentId": { "type": "string" },
        "status": { "type": "string" },
        "shippingAddress": { "$ref": "#/entities/Address" },
        "trackingNumber": { "type": "string" },
        "courierCompany": { "type": "string" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "buyerId", "sellerIds", "items", "totalAmount", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "description": "Represents a conversation between users.",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "productId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Represents a message in a conversation.",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "createdAt"]
    },
    "Review": {
        "title": "Review",
        "type": "object",
        "description": "Represents a review for an order.",
        "properties": {
            "orderId": { "type": "string" },
            "reviewerId": { "type": "string" },
            "revieweeId": { "type": "string" },
            "productId": { "type": "string" },
            "rating": { "type": "number" },
            "title": { "type": "string" },
            "content": { "type": "string" }
        },
        "required": ["orderId", "reviewerId", "revieweeId", "rating"]
    },
    "Notification": {
        "title": "Notification",
        "type": "object",
        "description": "Represents a user notification.",
        "properties": {
            "userId": { "type": "string" },
            "type": { "type": "string" },
            "title": { "type": "string" },
            "message": { "type": "string" },
            "data": { "type": "object" },
            "read": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "type", "message", "createdAt"]
    },
    "Delivery": {
        "title": "Delivery",
        "type": "object",
        "description": "Represents a delivery assignment.",
        "properties": {
            "orderId": { "type": "string" },
            "courierId": { "type": "string" },
            "status": { "type": "string" },
            "addresses": { "type": "object" },
            "proofOfDelivery": { "type": "string", "format": "uri" }
        },
        "required": ["orderId", "courierId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "apple.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "schema": { "$ref": "#/entities/User" } } },
      { "path": "/users/{userId}/addresses/{addressId}", "definition": { "schema": { "$ref": "#/entities/Address" } } },
      { "path": "/users/{userId}/paymentMethods/{methodId}", "definition": { "schema": { "$ref": "#/entities/PaymentMethod" } } },
      { "path": "/users/{userId}/wishlist/{productId}", "definition": { "schema": { "$ref": "#/entities/WishlistItem" } } },
      { "path": "/categories/{categoryId}", "definition": { "schema": { "$ref": "#/entities/Category" } } },
      { "path": "/brands/{brandId}", "definition": { "schema": { "$ref": "#/entities/Brand" } } },
      { "path": "/products/{productId}", "definition": { "schema": { "$ref": "#/entities/Product" } } },
      { "path": "/products/{productId}/offers/{offerId}", "definition": { "schema": { "$ref": "#/entities/Offer" } } },
      { "path": "/products/{productId}/bids/{bidId}", "definition": { "schema": { "$ref": "#/entities/Bid" } } },
      { "path": "/orders/{orderId}", "definition": { "schema": { "$ref": "#/entities/Order" } } },
      { "path": "/conversations/{conversationId}", "definition": { "schema": { "$ref": "#/entities/Conversation" } } },
      { "path": "/conversations/{conversationId}/messages/{messageId}", "definition": { "schema": { "$ref": "#/entities/Message" } } },
      { "path": "/reviews/{reviewId}", "definition": { "schema": { "$ref": "#/entities/Review" } } },
      { "path": "/notifications/{notificationId}", "definition": { "schema": { "$ref": "#/entities/Notification" } } },
      { "path": "/deliveries/{deliveryId}", "definition": { "schema": { "$ref": "#/entities/Delivery" } } },
      { "path": "/roles_admin/{userId}", "definition": { "schema": { "type": "object", "properties": {} }, "description": "Stores admin user roles." } }
    ]
  }
}
