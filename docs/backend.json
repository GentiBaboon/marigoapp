{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the MarigoApp marketplace.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "courier", "admin"] },
        "profileImage": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "language": { "type": "string", "enum": ["sq", "en", "it"] },
        "currency": { "type": "string", "enum": ["EUR", "ALL", "USD"] },
        "stripeCustomerId": { "type": "string" },
        "stripeAccountId": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "language", "currency", "createdAt"]
    },
    "Address": {
      "title": "Address",
      "type": "object",
      "description": "Represents a user's address.",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postal": { "type": "string" },
        "country": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["fullName", "address", "city", "postal", "country"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "type": "object",
      "description": "Represents a user's payment method.",
      "properties": {
        "type": { "type": "string" },
        "stripePaymentMethodId": { "type": "string" },
        "last4": { "type": "string" },
        "brand": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["stripePaymentMethodId", "last4", "brand"]
    },
    "WishlistItem": {
        "title": "WishlistItem",
        "type": "object",
        "description": "Represents a product in a user's wishlist.",
        "properties": {
            "addedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["addedAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a product category.",
      "properties": {
        "name": { "type": "object", "properties": { "sq": { "type": "string" }, "en": { "type": "string" }, "it": { "type": "string" } } },
        "slug": { "type": "string" },
        "parentId": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "position": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "slug", "isActive"]
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "description": "Represents a product brand.",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "verified": { "type": "boolean" },
        "productCount": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed on the marketplace.",
      "properties": {
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "brandId": { "type": "string" },
        "condition": { "type": "string", "enum": ["new", "like_new", "good", "fair"] },
        "listingType": { "type": "string", "enum": ["fixed_price", "auction"] },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "currency": { "type": "string", "enum": ["EUR", "ALL", "USD"] },
        "size": { "type": "string" },
        "color": { "type": "string" },
        "material": { "type": "string" },
        "gender": { "type": "string", "enum": ["women", "men", "children", "unisex"] },
        "images": { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "thumbnailUrl": { "type": "string" }, "position": { "type": "number" } } } },
        "status": { "type": "string", "enum": ["draft", "pending_review", "active", "sold", "removed", "expired"] },
        "views": { "type": "number" },
        "wishlistCount": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isAuthenticated": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "categoryId", "brandId", "condition", "listingType", "price", "currency", "images", "status", "createdAt"]
    },
    "Offer": {
      "title": "Offer",
      "type": "object",
      "description": "Represents an offer made on a product.",
      "properties": {
        "buyerId": { "type": "string" },
        "amount": { "type": "number" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "counterAmount": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "amount", "status"]
    },
    "Bid": {
      "title": "Bid",
      "type": "object",
      "description": "Represents a bid on an auction product.",
      "properties": {
        "bidderId": { "type": "string" },
        "amount": { "type": "number" },
        "isAutoBid": { "type": "boolean" },
        "maxAutoBidAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bidderId", "amount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents an order.",
      "properties": {
        "orderNumber": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "itemPrice": { "type": "number" },
        "commissionRate": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "shippingPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "paymentIntentId": { "type": "string" },
        "status": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "trackingNumber": { "type": "string" },
        "courierCompany": { "type": "string" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "buyerId", "sellerId", "productId", "totalAmount", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "description": "Represents a conversation between users.",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "productId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Represents a message in a conversation.",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "createdAt"]
    },
    "Review": {
        "title": "Review",
        "type": "object",
        "description": "Represents a review for an order.",
        "properties": {
            "orderId": { "type": "string" },
            "reviewerId": { "type": "string" },
            "revieweeId": { "type": "string" },
            "productId": { "type": "string" },
            "rating": { "type": "number" },
            "title": { "type": "string" },
            "content": { "type": "string" }
        },
        "required": ["orderId", "reviewerId", "revieweeId", "rating"]
    },
    "Notification": {
        "title": "Notification",
        "type": "object",
        "description": "Represents a user notification.",
        "properties": {
            "userId": { "type": "string" },
            "type": { "type": "string" },
            "title": { "type": "string" },
            "message": { "type": "string" },
            "data": { "type": "object" },
            "read": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "type", "message", "createdAt"]
    },
    "Delivery": {
        "title": "Delivery",
        "type": "object",
        "description": "Represents a delivery assignment.",
        "properties": {
            "orderId": { "type": "string" },
            "courierId": { "type": "string" },
            "status": { "type": "string" },
            "addresses": { "type": "object" },
            "proofOfDelivery": { "type": "string", "format": "uri" }
        },
        "required": ["orderId", "courierId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "apple.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "schema": { "$ref": "#/entities/User" } } },
      { "path": "/users/{userId}/addresses/{addressId}", "definition": { "schema": { "$ref": "#/entities/Address" } } },
      { "path": "/users/{userId}/paymentMethods/{methodId}", "definition": { "schema": { "$ref": "#/entities/PaymentMethod" } } },
      { "path": "/users/{userId}/wishlist/{productId}", "definition": { "schema": { "$ref": "#/entities/WishlistItem" } } },
      { "path": "/categories/{categoryId}", "definition": { "schema": { "$ref": "#/entities/Category" } } },
      { "path": "/brands/{brandId}", "definition": { "schema": { "$ref": "#/entities/Brand" } } },
      { "path": "/products/{productId}", "definition": { "schema": { "$ref": "#/entities/Product" } } },
      { "path": "/products/{productId}/offers/{offerId}", "definition": { "schema": { "$ref": "#/entities/Offer" } } },
      { "path": "/products/{productId}/bids/{bidId}", "definition": { "schema": { "$ref": "#/entities/Bid" } } },
      { "path": "/orders/{orderId}", "definition": { "schema": { "$ref": "#/entities/Order" } } },
      { "path": "/conversations/{conversationId}", "definition": { "schema": { "$ref": "#/entities/Conversation" } } },
      { "path": "/conversations/{conversationId}/messages/{messageId}", "definition": { "schema": { "$ref": "#/entities/Message" } } },
      { "path": "/reviews/{reviewId}", "definition": { "schema": { "$ref": "#/entities/Review" } } },
      { "path": "/notifications/{notificationId}", "definition": { "schema": { "$ref": "#/entities/Notification" } } },
      { "path": "/deliveries/{deliveryId}", "definition": { "schema": { "$ref": "#/entities/Delivery" } } },
      { "path": "/roles_admin/{userId}", "definition": { "schema": { "type": "object", "properties": {} }, "description": "Stores admin user roles." } }
    ]
  }
}
