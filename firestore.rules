rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    function isAdmin() {
      // Check for an 'admin' custom claim OR a specific developer admin UID.
      return isSignedIn() && (request.auth.token.admin == true || request.auth.uid == '2C81RVoXZWZuSWXEEueehqbHkMu1');
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }
    
    function isSellerInOrder() {
      return request.auth.uid in resource.data.sellerIds;
    }

    // --------------------------------------------------------------------
    // User Data Collections (/users/{userId}/*)
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId); // A user can create their own profile
      allow update, delete: if isOwner(userId) || isAdmin();
      
      // Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --------------------------------------------------------------------
    // Public Metadata (/categories, /brands)
    // --------------------------------------------------------------------
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections (/products)
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      // Only the seller or an admin can update/delete.
      allow update, delete: if (isExistingDoc() && isOwner(resource.data.sellerId)) || isAdmin();

      // Subcollections
      match /offers/{offerId} {
        function isProductSeller() {
          return get(/databases/$(database)/documents/products/$(productId)).data.sellerId == request.auth.uid;
        }

        allow get: if (isExistingDoc() && (isOwner(resource.data.buyerId) || isProductSeller())) || isAdmin();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
        allow update: if (isExistingDoc() && (isOwner(resource.data.buyerId) || isProductSeller())) || isAdmin();
        allow delete: if isAdmin();
      }
      match /bids/{bidId} {
         // Allow any signed-in user to bid for now. This could be more specific later.
         allow read, write: if isSignedIn();
      }
    }
    
    // --------------------------------------------------------------------
    // Transactional Collections (/orders, /reviews, /deliveries)
    // --------------------------------------------------------------------
    match /orders/{orderId} {
      // Solo gli admin possono leggere e scrivere gli ordini
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if (isExistingDoc() && isOwner(resource.data.reviewerId)) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
        allow get: if isSignedIn() && (isOwner(resource.data.courierId) || isAdmin());
        allow list, write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Communication Collections (/conversations, /notifications)
    // --------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow get, write: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all conversations
      
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
        allow get, list, write: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // --------------------------------------------------------------------
    // Moderation
    // --------------------------------------------------------------------
    match /reports/{reportId} {
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('reporterId');
        allow read, list, update, delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Admin Roles & Logs
    // --------------------------------------------------------------------
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Immutable logs
    }
  }
}
