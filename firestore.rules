rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    function isAdmin() {
      // Check for an 'admin' custom claim OR a specific developer admin UID.
      return isSignedIn() && (request.auth.token.admin == true || request.auth.uid == '2C81RVoXZWZuSWXEEueehqbHkMu1');
    }
    
    function isApprovedCourier() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.courierStatus == 'approved';
    }
    
    function isAssignedCourier(delivery) {
      return delivery.courierId == request.auth.uid;
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }
    
    function isPartyToOrder(delivery) {
        return isSignedIn() && (request.auth.uid == delivery.buyerId || request.auth.uid in delivery.sellerIds);
    }

    // --------------------------------------------------------------------
    // User Data Collections (/users/{userId}/*)
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId); // A user can create their own profile
      allow update, delete: if isOwner(userId) || isAdmin();
      
      // Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --------------------------------------------------------------------
    // Public Metadata (/categories, /brands)
    // --------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections (/products)
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      // Only the seller or an admin can update/delete.
      allow update, delete: if (isExistingDoc() && isOwner(resource.data.sellerId)) || isAdmin();

      // Subcollections
      match /offers/{offerId} {
        function isProductSeller() {
          return get(/databases/$(database)/documents/products/$(productId)).data.sellerId == request.auth.uid;
        }

        allow get: if (isExistingDoc() && (isOwner(resource.data.buyerId) || isProductSeller())) || isAdmin();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
        allow update: if (isExistingDoc() && (isOwner(resource.data.buyerId) || isProductSeller())) || isAdmin();
        allow delete: if isAdmin();
      }
      match /bids/{bidId} {
         // Allow any signed-in user to bid for now. This could be more specific later.
         allow read, write: if isSignedIn();
      }
    }
    
    // --------------------------------------------------------------------
    // Transactional Collections (/orders, /reviews, /deliveries)
    // --------------------------------------------------------------------
    match /orders/{orderId} {
      // Allow buyer, sellers, and admins to read the order.
      allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || request.auth.uid in resource.data.sellerIds) || isAdmin();
      allow list, update, delete: if isAdmin();
      allow create: if isSignedIn(); // Assume functions handle creation logic
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if (isExistingDoc() && isOwner(resource.data.reviewerId)) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
       // Allow involved parties to read/get, couriers to list available jobs
      allow get: if isPartyToOrder(resource.data) || isAssignedCourier(resource.data) || isAdmin();
      allow list: if isApprovedCourier() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isApprovedCourier() && (
          // Accepting a job
          (resource.data.courierId == null && request.resource.data.courierId == request.auth.uid && request.resource.data.status == 'assigned') ||
          // Courier updating their own assigned job, but cannot re-assign it
          (isAssignedCourier(resource.data) && request.resource.data.courierId == resource.data.courierId)
        )
      );
      allow delete: if isAdmin();
    }

    match /courier_profiles/{userId} {
        allow read, create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Communication Collections (/conversations, /notifications)
    // --------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow get, write: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all conversations
      
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
        allow get, list, write: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // --------------------------------------------------------------------
    // Moderation
    // --------------------------------------------------------------------
    match /reports/{reportId} {
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('reporterId');
        allow read, list, update, delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Admin & App Settings
    // --------------------------------------------------------------------
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Immutable logs
    }

    match /settings/{docId} {
        allow read: if true; // Allow public read for settings like maintenance mode
        allow write: if isAdmin();
    }

    match /coupons/{couponId} {
        allow read, write: if isAdmin();
    }
  }
}
