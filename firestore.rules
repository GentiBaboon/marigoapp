
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        request.auth.uid == '2C81RVoXZWZuSWXEEueehqbHkMu1' || 
        request.auth.uid == 'v521MWW9rmPYchVBc91DheeRU5j2' ||
        request.auth.uid == 'GoNLAq0YYdQw70fDS5L1XbBqtow1'
      );
    }
    
    function isApprovedCourier() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'courier';
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }
    
    function validProduct(p) {
      return p.sellerId == request.auth.uid 
          && p.title is string
          && p.price is number
          && p.status in ['draft', 'pending_review', 'active', 'sold', 'removed', 'expired'];
    }

    // --------------------------------------------------------------------
    // User Data Collections
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /cart/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && validProduct(request.resource.data);
      allow update: if (isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin()));
      allow delete: if (isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin()));

      match /offers/{offerId} {
        allow read: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId) || isAdmin());
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
        allow update: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId) || isAdmin());
        allow delete: if isAdmin();
      }
    }
    
    match /orders/{orderId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid in resource.data.sellerIds || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid in resource.data.sellerIds || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    match /deliveries/{deliveryId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.courierId == request.auth.uid || resource.data.buyerId == request.auth.uid || request.auth.uid in resource.data.sellerIds || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /courier_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
        allow read, list, update: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow delete: if isAdmin();
    }
    
    match /support_chats/{chatId} {
      allow read, create, update: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow list, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && (request.auth.uid == get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId || isAdmin());
        allow list, update, delete: if isAdmin();
      }
    }
    
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /settings/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /config/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}
