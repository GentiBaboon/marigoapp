rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      // resource is the document *before* the request.
      // It is null on 'create' operations.
      return resource != null;
    }

    function isAdmin() {
      // Allows access if the user has an 'admin' custom claim, OR if they are the designated developer admin.
      // In a production environment, you might remove the hardcoded UID.
      return isSignedIn() && (request.auth.token.admin == true || request.auth.uid == '2C81RVoXZWZuSWXEEueehqbHkMu1');
    }
    
    function isApprovedCourier() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.courierStatus == 'approved';
    }
    
    function isAssignedCourier(delivery) {
      return delivery.courierId == request.auth.uid;
    }

    // Ensures the UID in the incoming data for a given field matches the authenticated user.
    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }
    
    function isPartyToOrder(delivery) {
        return isSignedIn() && (request.auth.uid == delivery.buyerId || request.auth.uid in delivery.sellerIds);
    }
    
    // Validates the data structure for a new or updated product.
    function validProduct(productData) {
        return productData.title is string && productData.title.size() > 0 && productData.title.size() < 100
            && productData.price is number && productData.price > 0
            && productData.category is string && productData.category.size() > 0
            && productData.images is list && productData.images.size() > 0 && productData.images.size() <= 15
            && productData.status is string && productData.status == 'pending_review' // New products must be pending review
            && productData.sellerId == request.auth.uid;
    }
    
    // Validates an update to a product. Seller cannot be changed.
    function validProductUpdate(updateData, existingData) {
        return updateData.title is string && updateData.title.size() > 0 && updateData.title.size() < 100
            && updateData.price is number && updateData.price > 0
            && updateData.category is string && updateData.category.size() > 0
            && updateData.images is list && updateData.images.size() > 0 && updateData.images.size() <= 15
            && updateData.sellerId == existingData.sellerId;
    }

    // --------------------------------------------------------------------
    // User Data Collections (/users/{userId}/*)
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --------------------------------------------------------------------
    // Public Metadata (/categories, /brands)
    // --------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections (/products)
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get, list: if true;
      // Users can create products if the data is valid and they are the declared seller.
      allow create: if isSignedIn() && validProduct(request.resource.data);
      // The product owner (seller) can update it if the data is valid, or an admin can.
      allow update: if (isOwner(resource.data.sellerId) && validProductUpdate(request.resource.data, resource.data)) || isAdmin();
      // The seller or an admin can delete a product.
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();

      match /offers/{offerId} {
        function isProductSeller() {
          return get(/databases/$(database)/documents/products/$(productId)).data.sellerId == request.auth.uid;
        }

        allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || isProductSeller());
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
        allow update: if isSignedIn() && (isOwner(resource.data.buyerId) || isProductSeller());
        allow delete: if isAdmin();
      }
      match /bids/{bidId} {
         allow read, write: if isSignedIn();
      }
    }
    
    // --------------------------------------------------------------------
    // Transactional Collections (/orders, /reviews, /deliveries)
    // --------------------------------------------------------------------
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || request.auth.uid in resource.data.sellerIds) || isAdmin();
      // Orders can only be created via the `createPaymentIntent` Cloud Function, which uses the Admin SDK.
      allow create: if false; 
      allow list, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if isOwner(resource.data.reviewerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
      allow get: if isPartyToOrder(resource.data) || isAssignedCourier(resource.data) || isAdmin();
      allow list: if isApprovedCourier() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isApprovedCourier() && (
          (resource.data.courierId == null && request.resource.data.courierId == request.auth.uid && request.resource.data.status == 'assigned') ||
          (isAssignedCourier(resource.data) && request.resource.data.courierId == resource.data.courierId)
        )
      );
      allow delete: if isAdmin();
    }

    match /courier_profiles/{userId} {
        allow read, create, update: if isOwner(userId) || isAdmin();
        allow list, delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Communication Collections (/conversations, /notifications)
    // --------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow get, write: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow list: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
        // Users can only access their own notifications.
        allow read, list, update: if isOwner(resource.data.userId);
        // Notifications are created by backend functions, not clients directly.
        allow create: if false;
        allow delete: if isAdmin();
    }
    
    match /support_chats/{chatId} {
      allow read, create, update: if isOwner(resource.data.userId);
      allow list, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isOwner(get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId);
        allow list, update, delete: if isAdmin();
      }
    }
    
    // --------------------------------------------------------------------
    // Moderation
    // --------------------------------------------------------------------
    match /reports/{reportId} {
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('reporterId');
        allow read, list, update, delete: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Admin & App Settings
    // --------------------------------------------------------------------
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /settings/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /coupons/{couponId} {
        // Anyone can read a coupon to see if it's valid.
        allow read: if true;
        allow write: if isAdmin();
    }

    match /config/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}