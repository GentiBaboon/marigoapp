
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        request.auth.uid in [
          '2C81RVoXZWZuSWXEEueehqbHkMu1', 
          'v521MWW9rmPYchVBc91DheeRU5j2',
          'GoNLAq0YYdQw70fDS5L1XbBqtow1',
          '4qTAOIovwdWYGCnqYPiPCJqNcdP2',
          'jBbMqpl6zKeZ9skDW3ux0iBMJRB2'
        ]
      );
    }
    
    function isCourier() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'courier';
    }

    // Data Validation
    function validProduct(p) {
      return p.title is string && p.title.size() >= 5 && p.title.size() <= 100
          && p.price is number && p.price > 0
          && p.status in ['active', 'draft', 'pending_review', 'sold', 'removed', 'expired'];
    }

    // --------------------------------------------------------------------
    // Collections
    // --------------------------------------------------------------------
    
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /wishlist/{productId} { allow read, write: if isOwner(userId); }
      match /cart/{productId} { allow read, write: if isOwner(userId); }
      match /addresses/{addressId} { allow read, write: if isOwner(userId); }
      match /paymentMethods/{methodId} { allow read, write: if isOwner(userId); }
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && validProduct(request.resource.data);
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid && resource.data.status == 'draft');

      match /offers/{offerId} {
        allow read: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId) || isAdmin());
        allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
        allow update: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId) || isAdmin());
      }
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid in resource.data.sellerIds || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid in resource.data.sellerIds || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /deliveries/{deliveryId} {
      allow read: if isSignedIn() && (resource.data.courierId == request.auth.uid || isAdmin() || request.auth.uid == resource.data.buyerId);
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.courierId == request.auth.uid || isCourier()));
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /config/exchangeRates {
      allow read: if true;
    }
    
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
