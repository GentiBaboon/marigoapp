rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }

    function isOwnerFieldUnchanged(ownerFieldName) {
      return request.resource.data[ownerFieldName] == resource.data[ownerFieldName];
    }
    
    function isSellerInOrder() {
      return request.auth.uid in resource.data.sellerIds;
    }

    // --------------------------------------------------------------------
    // User Data Collections (/users/{userId}/*)
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
      
      // Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId);
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --------------------------------------------------------------------
    // Public Metadata (/categories, /brands)
    // --------------------------------------------------------------------
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections (/products)
    // --------------------------------------------------------------------
    match /products/{productId} {
      // Public can view active products. Sellers can view their own products.
      allow get: if (resource.data.status == 'active') || (isSignedIn() && resource.data.sellerId == request.auth.uid) || isAdmin();
      // Signed-in users can perform queries (e.g., for their own products, or for active products).
      // The `get` rule above provides the document-level security.
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('sellerId');
      allow update, delete: if isExistingDoc() && isOwner(resource.data.sellerId);

      // Subcollections
      match /offers/{offerId} {
        function isProductSeller() {
          return isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId);
        }

        allow get: if isProductSeller() || (isExistingDoc() && isOwner(resource.data.buyerId));
        allow list: if isSignedIn();
        allow create: if isCorrectOwnerInRequestData('buyerId');
        allow update: if (isProductSeller() && (request.resource.data.status == 'accepted' || request.resource.data.status == 'rejected' || request.resource.data.status == 'countered'))
              || (isOwner(resource.data.buyerId) && request.resource.data.status == 'withdrawn')
              || (isOwner(resource.data.buyerId) && resource.data.status == 'countered' && (request.resource.data.status == 'accepted' || request.resource.data.status == 'rejected'));
        allow delete: if false; 
      }
      match /bids/{bidId} {
         allow read, write: if isSignedIn() && (isOwner(request.resource.data.bidderId) || isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId));
      }
    }
    
    // --------------------------------------------------------------------
    // Transactional Collections (/orders, /reviews, /deliveries)
    // --------------------------------------------------------------------
    match /orders/{orderId} {
      allow get, update: if isSignedIn() && (isOwner(resource.data.buyerId) || isSellerInOrder() || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if isExistingOwner(resource.data.reviewerId);
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
        allow get: if isSignedIn() && (isOwner(resource.data.courierId) || isAdmin());
        allow list, write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Communication Collections (/conversations, /notifications)
    // --------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow get, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if false;
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
    
    match /notifications/{notificationId} {
        allow read, write: if isOwner(resource.data.userId);
        allow list: if isSignedIn();
    }
    
    // --------------------------------------------------------------------
    // Admin Roles
    // --------------------------------------------------------------------
    match /roles_admin/{userId} {
      allow get, list, write: if isAdmin();
    }
  }
}
