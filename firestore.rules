rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.admin == true || request.auth.uid == '2C81RVoXZWZuSWXEEueehqbHkMu1');
    }
    
    function isApprovedCourier() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.courierStatus == 'approved';
    }
    
    function isAssignedCourier(delivery) {
      return delivery.courierId == request.auth.uid;
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }
    
    function isPartyToOrder(delivery) {
        return isSignedIn() && (request.auth.uid == delivery.buyerId || request.auth.uid in delivery.sellerIds);
    }
    
    // Prodotto valido per la creazione (shell iniziale)
    function validProduct(productData) {
      let isCorrectSeller = productData.sellerId == request.auth.uid;
      let isCorrectStatus = productData.status == 'pending_review';
      // Robust check for initial state: images must be an empty list, title and price must be valid
      return isCorrectSeller 
          && isCorrectStatus 
          && productData.images.size() == 0
          && productData.title.size() > 0
          && productData.price > 0;
    }
    
    // Validazione aggiornamento (per aggiunta immagini o modifiche)
    function validProductUpdate(updateData, existingData) {
        let sellerUnchanged = !('sellerId' in updateData) || updateData.sellerId == existingData.sellerId;
        
        // Se si stanno aggiungendo immagini a un prodotto che non ne aveva (caso tipico del nostro flusso di upload)
        if (existingData.images.size() == 0 && 'images' in updateData && updateData.images.size() > 0) {
            return updateData.images.size() <= 15 && sellerUnchanged;
        }

        return sellerUnchanged;
    }

    // --------------------------------------------------------------------
    // User Data Collections
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && validProduct(request.resource.data);
      allow update: if (isOwner(resource.data.sellerId) && validProductUpdate(request.resource.data, resource.data)) || isAdmin();
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();

      match /offers/{offerId} {
        function isProductSeller() {
          return get(/databases/$(database)/documents/products/$(productId)).data.sellerId == request.auth.uid;
        }
        allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || isProductSeller());
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
        allow update: if isSignedIn() && (isOwner(resource.data.buyerId) || isProductSeller());
        allow delete: if isAdmin();
      }
      match /bids/{bidId} {
         allow read, write: if isSignedIn();
      }
    }
    
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || request.auth.uid in resource.data.sellerIds) || isAdmin();
      allow create: if false; 
      allow list, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if isOwner(resource.data.reviewerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
      allow get: if isPartyToOrder(resource.data) || isAssignedCourier(resource.data) || isAdmin();
      allow list: if isApprovedCourier() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isApprovedCourier() && (
          (resource.data.courierId == null && request.resource.data.courierId == request.auth.uid && request.resource.data.status == 'assigned') ||
          (isAssignedCourier(resource.data) && request.resource.data.courierId == resource.data.courierId)
        )
      );
      allow delete: if isAdmin();
    }

    match /courier_profiles/{userId} {
        allow read, create, update: if isOwner(userId) || isAdmin();
        allow list, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow get, write: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow list: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
        allow read, list, update: if isOwner(resource.data.userId);
        allow create: if false;
        allow delete: if isAdmin();
    }
    
    match /support_chats/{chatId} {
      allow read, create, update: if isOwner(resource.data.userId);
      allow list, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isOwner(get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId);
        allow list, update, delete: if isAdmin();
      }
    }
    
    match /reports/{reportId} {
        allow create: if isSignedIn() && isCorrectOwnerInRequestData('reporterId');
        allow read, list, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /settings/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /coupons/{couponId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /config/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}