rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    function isAdmin() {
      // Check for an 'admin' custom claim on the user's token.
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isCorrectOwnerInRequestData(ownerFieldName) {
      return request.resource.data[ownerFieldName] == request.auth.uid;
    }

    function isOwnerFieldUnchanged(ownerFieldName) {
      return request.resource.data[ownerFieldName] == resource.data[ownerFieldName];
    }
    
    function isSellerInOrder() {
      return request.auth.uid in resource.data.sellerIds;
    }

    // --------------------------------------------------------------------
    // User Data Collections (/users/{userId}/*)
    // --------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId) || isAdmin();
      
      // Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --------------------------------------------------------------------
    // Public Metadata (/categories, /brands)
    // --------------------------------------------------------------------
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{brandId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Marketplace Collections (/products)
    // --------------------------------------------------------------------
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('sellerId');
      allow update, delete: if (isExistingDoc() && isOwner(resource.data.sellerId)) || isAdmin();

      // Subcollections
      match /offers/{offerId} {
        function isProductSeller() {
          return isOwner(get(/databases/$(database)/documents/products/$(productId)).data.sellerId);
        }

        allow get: if isProductSeller() || (isExistingDoc() && isOwner(resource.data.buyer_id)) || isAdmin();
        allow list: if isSignedIn() || isAdmin();
        allow create: if isCorrectOwnerInRequestData('buyerId') && request.resource.data.sellerId == get(/databases/$(database)/documents/products/$(productId)).data.sellerId;
        
        allow update: if (isOwner(resource.data.buyerId) && request.resource.data.status == 'withdrawn')
                    || (isProductSeller() && resource.data.status == 'pending' && (request.resource.data.status in ['accepted', 'declined', 'countered']))
                    || (isOwner(resource.data.buyerId) && resource.data.status == 'countered' && (request.resource.data.status in ['accepted', 'declined']))
                    || isAdmin();

        allow delete: if isAdmin(); 
      }
      match /bids/{bidId} {
         allow read, write: if isSignedIn() || isAdmin();
      }
    }
    
    // --------------------------------------------------------------------
    // Transactional Collections (/orders, /reviews, /deliveries)
    // --------------------------------------------------------------------
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || isSellerInOrder()) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('buyerId');
      allow update: if isAdmin() || (isSignedIn() && (isOwner(resource.data.buyerId) || isSellerInOrder()));
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isCorrectOwnerInRequestData('reviewerId');
      allow update: if isExistingOwner(resource.data.reviewerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /deliveries/{deliveryId} {
        allow get: if isSignedIn() && (isOwner(resource.data.courierId) || isAdmin());
        allow list, write: if isAdmin();
    }

    // --------------------------------------------------------------------
    // Communication Collections (/conversations, /notifications)
    // --------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow get, write: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow list: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
        allow read, write: if isOwner(resource.data.userId) || isAdmin();
        allow list: if isAdmin();
    }
    
    // --------------------------------------------------------------------
    // Admin Roles
    // --------------------------------------------------------------------
    match /roles_admin/{userId} {
      allow get, list, write: if isAdmin();
    }
  }
}
